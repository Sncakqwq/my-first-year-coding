#include <bits/stdc++.h>
using namespace std;
typedef long long ll;
int main() 
{
    ll ans=0;
    for(ll i=1;i<=20250412;i++)
    {
        ll x=i;
        ll cnt0=0,cnt2=0,cnt5=0;
        while(x!=0)
        {
            ll temp=x%10;
            
            if(temp==0) cnt0++;
            if(temp==2) cnt2++;
            if(temp==5) cnt5++;
            x/=10;
        }
        if(cnt0>=1&&cnt2>=2&&cnt5>=1) ans++;
        
    }
    cout << ans;

    return 0;
}
